<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Evolution of Computer</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans">

<div class="max-w-6xl mx-auto p-6">
  <h1 class="text-3xl font-bold text-indigo-600 mb-6 text-center">1.2 Evolution of Computer</h1>

  <!-- Navigation -->
  <div class="flex justify-center gap-2 mb-6 flex-wrap">
    <button onclick="showSection('first')" class="bg-indigo-500 text-white px-4 py-2 rounded">1st Gen</button>
    <button onclick="showSection('second')" class="bg-indigo-500 text-white px-4 py-2 rounded">2nd Gen</button>
    <button onclick="showSection('third')" class="bg-indigo-500 text-white px-4 py-2 rounded">3rd Gen</button>
    <button onclick="showSection('fourth')" class="bg-indigo-500 text-white px-4 py-2 rounded">4th Gen</button>
    <button onclick="showSection('fifth')" class="bg-indigo-500 text-white px-4 py-2 rounded">5th Gen</button>
    <button onclick="showSection('quiz')" class="bg-indigo-500 text-white px-4 py-2 rounded">Quiz</button>
    <button onclick="showSection('assignment')" class="bg-indigo-500 text-white px-4 py-2 rounded">Assignment</button>
    <button onclick="showSection('tps')" class="bg-indigo-500 text-white px-4 py-2 rounded">TPS/TGS</button>
  </div>

  <!-- First Generation -->
  <div id="first" class="section">
    <h2 class="text-xl font-semibold mb-2">First Generation (1940–1956)</h2>
    <p><b>Main Technology:</b> Vacuum Tubes</p>
    <p class="mb-2">Vacuum tubes were used to control electrical signals. These machines were very large, consumed huge amounts of electricity, and produced excessive heat.</p>

    <p><b>Examples:</b> ENIAC, EDVAC, UNIVAC I</p>

    <p class="mt-2"><b>Characteristics:</b></p>
    <ul class="list-disc ml-6">
      <li>Very large in size (room-sized)</li>
      <li>High power consumption</li>
      <li>Generated excessive heat</li>
      <li>Very expensive</li>
      <li>Low reliability</li>
      <li>Machine language used</li>
    </ul>

    <p class="mt-2"><b>Interesting Facts:</b></p>
    <ul class="list-disc ml-6">
      <li>ENIAC occupied about 1800 square feet</li>
      <li>Used about 18,000 vacuum tubes</li>
      <li>Frequent failures due to overheating</li>
    </ul>
  </div>

  <!-- Second Generation -->
  <div id="second" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">Second Generation (1956–1963)</h2>
    <p><b>Main Technology:</b> Transistors</p>
    <p class="mb-2">Transistors replaced vacuum tubes, making computers smaller, faster, and more energy-efficient.</p>

    <p><b>Examples:</b> IBM 1401, IBM 7094, CDC 1604</p>

    <p class="mt-2"><b>Characteristics:</b></p>
    <ul class="list-disc ml-6">
      <li>Smaller size compared to first generation</li>
      <li>Less heat generation</li>
      <li>More reliable</li>
      <li>Faster processing speed</li>
      <li>Assembly language used</li>
    </ul>

    <p class="mt-2"><b>Interesting Facts:</b></p>
    <ul class="list-disc ml-6">
      <li>Transistors reduced size significantly</li>
      <li>Used in early commercial computers</li>
      <li>Marked the beginning of modern computing</li>
    </ul>
  </div>

  <!-- Third Generation -->
  <div id="third" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">Third Generation (1964–1971)</h2>
    <p><b>Main Technology:</b> Integrated Circuits (IC)</p>
    <p class="mb-2">ICs combined multiple transistors into a single chip, increasing efficiency and reducing size.</p>

    <p><b>Examples:</b> IBM System/360, PDP-8, PDP-11</p>

    <p class="mt-2"><b>Characteristics:</b></p>
    <ul class="list-disc ml-6">
      <li>Much smaller size</li>
      <li>High speed and efficiency</li>
      <li>Reduced power consumption</li>
      <li>More reliable</li>
      <li>High-level languages used (C, COBOL)</li>
    </ul>

    <p class="mt-2"><b>Interesting Facts:</b></p>
    <ul class="list-disc ml-6">
      <li>First use of operating systems</li>
      <li>Multiple users could use computer at same time</li>
      <li>Introduction of keyboards and monitors</li>
    </ul>
  </div>

  <!-- Fourth Generation -->
  <div id="fourth" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">Fourth Generation (1971–Present)</h2>
    <p><b>Main Technology:</b> Microprocessors</p>
    <p class="mb-2">Microprocessors integrated thousands of ICs into a single chip, leading to the development of personal computers.</p>

    <p><b>Examples:</b> Intel 4004, Apple II, IBM PC</p>

    <p class="mt-2"><b>Characteristics:</b></p>
    <ul class="list-disc ml-6">
      <li>Very small size</li>
      <li>Very high speed</li>
      <li>Low cost</li>
      <li>Portable devices introduced</li>
      <li>User-friendly interfaces</li>
    </ul>

    <p class="mt-2"><b>Interesting Facts:</b></p>
    <ul class="list-disc ml-6">
      <li>Birth of personal computers (PCs)</li>
      <li>Introduction of graphical user interface (GUI)</li>
      <li>Rapid growth of software industry</li>
    </ul>
  </div>

  <!-- Fifth Generation -->
  <div id="fifth" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">Fifth Generation (Present & Future)</h2>
    <p><b>Main Technology:</b> Artificial Intelligence (AI)</p>
    <p class="mb-2">Focuses on developing smart systems that can think, learn, and make decisions like humans.</p>

    <p><b>Examples:</b> AI systems, robots, self-driving cars, virtual assistants</p>

    <p class="mt-2"><b>Characteristics:</b></p>
    <ul class="list-disc ml-6">
      <li>Use of artificial intelligence</li>
      <li>Machine learning and deep learning</li>
      <li>Natural language processing</li>
      <li>Automation and robotics</li>
      <li>Extremely high processing power</li>
    </ul>

    <p class="mt-2"><b>Interesting Facts:</b></p>
    <ul class="list-disc ml-6">
      <li>Computers can understand human language</li>
      <li>Used in self-driving vehicles</li>
      <li>Used in smart assistants like voice AI</li>
    </ul>
  </div>

  <!-- Quiz -->
  <div id="quiz" class="section hidden">
    <h2 class="text-xl font-semibold mb-4">Technical Quiz</h2>
    <div id="quizContainer"></div>
    <button onclick="submitQuiz()" class="mt-4 bg-green-500 text-white px-4 py-2 rounded">Submit</button>
    <p id="score" class="mt-3 font-bold"></p>
  </div>

  <!-- Assignment -->
  <div id="assignment" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">Project / Home Assignment</h2>
    <p class="mb-2">The following project work focuses mainly on presentation-based tasks along with other creative activities:</p>
    <ul class="list-disc ml-6">
      <li>Prepare a PowerPoint presentation explaining all five generations of computers with suitable examples.</li>
      <li>Create a slide presentation comparing technologies used in each generation.</li>
      <li>Design a visual timeline (chart or digital slide) showing the evolution of computers.</li>
      <li>Write a short report on how computer generations improved over time.</li>
      <li>Prepare a poster or infographic showing key features of each generation.</li>
      <li>Research any one computer (e.g., ENIAC, IBM PC) and present its features.</li>
    </ul>
  </div>

  <!-- TPS/TGS -->
  <div id="tps" class="section hidden">
    <h2 class="text-xl font-semibold mb-2">TPS and TGS Activities</h2>

    <p class="mb-2"><b>TPS (Think-Pair-Share):</b></p>
    <ul class="list-disc ml-6 mb-3">
      <li>Think: Identify key differences between first and latest generation computers.</li>
      <li>Pair: Discuss how technology improved from vacuum tubes to artificial intelligence.</li>
      <li>Share: Present ideas and conclusions in front of the class.</li>
    </ul>

    <p class="mb-2"><b>TGS (Team Game Strategy):</b></p>
    <ul class="list-disc ml-6">
      <li>Divide students into groups or teams.</li>
      <li>Ask questions related to different generations of computers.</li>
      <li>Each correct answer earns points for the team.</li>
      <li>The team with the highest score at the end is declared the winner.</li>
    </ul>
  </div>

</div>

<script>
const questions = [
  {q: "First generation used?", options: ["Transistors","Vacuum Tubes","IC"], ans: 1},
  {q: "Second generation used?", options: ["IC","Transistors","AI"], ans: 1},
  {q: "Third generation technology?", options: ["IC","Vacuum","AI"], ans: 0},
  {q: "Microprocessor belongs to?", options: ["4th","3rd","2nd"], ans: 0},
  {q: "AI is used in?", options: ["5th","2nd","1st"], ans: 0},
  {q: "ENIAC belongs to?", options: ["1st","2nd","3rd"], ans: 0},
  {q: "IBM PC belongs to?", options: ["4th","1st","2nd"], ans: 0},
  {q: "IC means?", options: ["Integrated Circuit","Internal Chip","Input Circuit"], ans: 0},
  {q: "Transistor replaced?", options: ["Vacuum","IC","AI"], ans: 0},
  {q: "Modern AI belongs to?", options: ["5th","4th","3rd"], ans: 0}
];

const container = document.getElementById('quizContainer');
questions.forEach((item, index) => {
  const div = document.createElement('div');
  div.className = "mb-3";
  div.innerHTML = `<p>${index+1}. ${item.q}</p>` +
    item.options.map((opt,i)=>`<label><input type='radio' name='q${index}' value='${i}'> ${opt}</label><br>`).join('');
  container.appendChild(div);
});

function submitQuiz(){
  let score = 0;
  questions.forEach((q,i)=>{
    const selected = document.querySelector(`input[name='q${i}']:checked`);
    if(selected && parseInt(selected.value) === q.ans) score++;
  });
  document.getElementById('score').innerText = "Score: " + score + "/" + questions.length;
}

function showSection(id) {
  document.querySelectorAll('.section').forEach(sec => sec.classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}
</script>

</body>
</html>
